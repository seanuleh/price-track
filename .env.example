# PocketBase admin credentials (used by both schema init and the worker)
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=changeme

# Worker: PocketBase connection (use localhost:8090 if worker runs in same container)
POCKETBASE_URL=http://localhost:8090
POCKETBASE_ADMIN_EMAIL=admin@example.com
POCKETBASE_ADMIN_PASSWORD=changeme

# How often the scheduler checks prices (minutes)
CHECK_INTERVAL_MINUTES=60

# Claude CLI — AI-powered price detection and retailer discovery
# Mount your claude binary and config into the container (see docker-compose example)
CLAUDE_BIN=/usr/local/bin/claude
CLAUDE_HOME=/root
